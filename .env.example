# Production Error Handling Configuration
NODE_ENV=production

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_TO_EMAIL=your-email@domain.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Error Logging Configuration
# Set to 'true' only if you need stack traces in production logs (not recommended for security)
LOG_STACK_TRACES=false

# Optional: Add your logging service configuration
# SENTRY_DSN=your_sentry_dsn_here
# LOGROCKET_APP_ID=your_logrocket_app_id_here